# Deployment mode (development | staging | production)
DSRN_MODE=development

# Peer node
DSRN_PEER_PORT=8060
DSRN_P2P_PORT=4001

# Consensus engine
CONSENSUS_PORT=8061
PBFT_MIN_PEERS=4
PBFT_TIMEOUT_SECS=30
PBFT_MAX_ROUNDS=3

# Gossip protocol
GOSSIP_PORT=8062
GOSSIP_FANOUT=3
GOSSIP_INTERVAL_SECS=15
GOSSIP_MAX_HOPS=10
GOSSIP_MAX_AGE_HOURS=24

# Response coordinator
RESPONSE_PORT=8063

# Trust manager
TRUST_MANAGER_PORT=8064
TRUST_MIN_REPUTATION=60

# Blockchain ledger
LEDGER_PORT=8065
LEDGER_BLOCK_INTERVAL_SECS=60
LEDGER_MAX_TX_PER_BLOCK=100

# Network monitor
MONITOR_PORT=8066

# Dashboard API
DSRN_DASHBOARD_PORT=8067

# Privacy budget
PRIVACY_MAX_INTEL_PER_DAY=1000
PRIVACY_MAX_PROPOSALS_PER_DAY=100

# Service URLs (auto-resolved in Docker, override for staging/prod)
PEER_NODE_URL=http://dsrn-peer-node:8060
CONSENSUS_ENGINE_URL=http://dsrn-consensus-engine:8061
GOSSIP_URL=http://dsrn-threat-gossip:8062
RESPONSE_COORDINATOR_URL=http://dsrn-response-coordinator:8063
TRUST_MANAGER_URL=http://dsrn-peer-trust-manager:8064
LEDGER_URL=http://dsrn-blockchain-ledger:8065
MONITOR_URL=http://dsrn-network-monitor:8066
